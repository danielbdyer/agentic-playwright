{
  "typescript.tsdk": "node_modules/typescript/lib",
  "terminal.integrated.defaultProfile.windows": "WSL Ubuntu (zsh)",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.profiles.windows": {
    "WSL Ubuntu (zsh)": {
      "path": "C:\\Windows\\System32\\wsl.exe",
      "args": ["-d", "Ubuntu", "zsh", "-l"],
      "icon": "terminal-bash"
    }
  },
  "terminal.integrated.profiles.linux": {
    "zsh": {
      "path": "/usr/bin/zsh",
      "args": ["-l"],
      "icon": "terminal-bash"
    }
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/test-results": true,
    "**/tests-capture": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/test-results/**": true,
    "**/tests-capture/**": true,
    "**/.tesseract/runs/**": true,
    "**/.tesseract/sessions/**": true
  }
}
