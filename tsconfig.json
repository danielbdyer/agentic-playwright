{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": [
    "bin/**/*.ts",
    "fixtures/**/*.ts",
    "knowledge/**/*.ts",
    "lib/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "dist",
    "generated",
    "node_modules",
    "tests"
  ]
}
