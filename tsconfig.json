{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "bin/**/*.ts",
    "dogfood/fixtures/**/*.ts",
    "dogfood/fixtures/**/*.tsx",
    "dogfood/knowledge/**/*.ts",
    "product/**/*.ts",
    "workshop/**/*.ts",
    "workshop/**/*.tsx",
    "dashboard/mcp/**/*.ts",
    "dashboard/bridges/**/*.ts",
    "dashboard/projections/**/*.ts",
    "dashboard/server.ts",
    "dashboard/server/**/*.ts",
    "playwright*.ts",
    "tests/**/*.ts",
    "tests-capture/**/*.ts"
  ],
  "exclude": [
    "dist",
    "dogfood/.ado-sync",
    ".tesseract",
    "dogfood/generated",
    "generated",
    "product/generated",
    "node_modules",
    "test-results"
  ]
}
