[user]
	name = Danny
	email = danielbdyer@gmail.com

[core]
	editor = code --wait
	autocrlf = input
	excludesfile = ~/.gitignore_global

[init]
	defaultBranch = main

[fetch]
	prune = true

[pull]
	ff = only

[rebase]
	autoStash = true

[merge]
	conflictStyle = diff3

[rerere]
	enabled = true

[alias]
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	lg = log --graph --decorate --oneline --all
	last = log -1 HEAD --stat