# Proposed ~/.zshrc
# Purpose: make Zsh the single interactive shell with clean VS Code integration.

# VS Code shell integration should load in the shell you actually use.
if [[ "$TERM_PROGRAM" == "vscode" ]] && command -v code >/dev/null 2>&1; then
  . "$(code --locate-shell-integration-path zsh)"
fi

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="agnoster"
plugins=(git)

# Older NVM releases use unmatched globs that error under Zsh's default
# `nomatch` behavior. This keeps NVM commands quiet and predictable.
unsetopt nomatch

# Reuse a single SSH agent across shells when possible.
start_ssh_agent() {
  local agent_env="$HOME/.ssh/agent.env"
  if [[ -r "$agent_env" ]]; then
    . "$agent_env" >/dev/null
  fi
  if ! ssh-add -l >/dev/null 2>&1; then
    umask 077
    ssh-agent -s | sed 's/^echo/#echo/' > "$agent_env"
    . "$agent_env" >/dev/null
  fi
}

if command -v ssh-agent >/dev/null 2>&1 && command -v ssh-add >/dev/null 2>&1; then
  start_ssh_agent
fi

# Lazy-load NVM only when Node tooling is used.
load_nvm() {
  unset -f load_nvm nvm node npm npx corepack pnpm pnpx
  [[ -s "$NVM_DIR/nvm.sh" ]] && . "$NVM_DIR/nvm.sh"
  [[ -s "$NVM_DIR/bash_completion" ]] && . "$NVM_DIR/bash_completion"
  if command -v nvm >/dev/null 2>&1; then
    nvm use --silent default >/dev/null 2>&1 || nvm use --silent node >/dev/null 2>&1 || true
  fi
}

nvm() { load_nvm; nvm "$@"; }
node() { load_nvm; node "$@"; }
npm() { load_nvm; npm "$@"; }
npx() { load_nvm; npx "$@"; }
corepack() { load_nvm; corepack "$@"; }
pnpm() { load_nvm; command pnpm "$@"; }
pnpx() { load_nvm; command pnpx "$@"; }

# Optional dircolors.
if [[ -f "$HOME/.dircolors" ]] && command -v dircolors >/dev/null 2>&1; then
  eval "$(dircolors -b "$HOME/.dircolors")"
fi

if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

source "$ZSH/oh-my-zsh.sh"

# Python virtualenvwrapper, loaded only if installed.
export WORKON_HOME="$HOME/.virtualenvs"
export VIRTUALENVWRAPPER_PYTHON=/usr/bin/python3
export VIRTUALENVWRAPPER_VIRTUALENV="$HOME/.local/bin/virtualenv"
if [[ -f "$HOME/.local/bin/virtualenvwrapper.sh" ]]; then
  source "$HOME/.local/bin/virtualenvwrapper.sh"
fi
