node_modules/
dist/
dashboard/dashboard.js
dashboard/styles.css
workshop/synthetic-app/synthetic-app.js
playwright-report/
test-results/
.npm-cache
.tools
.claude/worktrees/

# ── Runtime engine (.tesseract) ──────────────────────────────────
# Bulk-ignore everything under .tesseract/; the engine recreates it.
# Allowlist only governance anchors that must survive across clones.
.tesseract/*
!.tesseract/policy/
!.tesseract/policy/trust-policy.yaml
# ── Dogfood clean room ───────────────────────────────────────────
# All training data lives under dogfood/.  The flywheel regenerates
# from scratch on each cold-start run.  Never merge evolvable
# surfaces back to main — only merge business logic improvements.
dogfood/

# Auto-activated hints are ephemeral outputs of the speedrun loop.
# They are regenerated from scratch and should not be committed.
knowledge/screens/*.hints.yaml

# Deterministic compiler output.  Regenerated as a build step.
# Production suites will track lib/generated/ once they exist.
# Hand-authored DSL files moved to lib/domain/ (workflow-facade.ts,
# agent-dsl.ts); lib/generated/ now contains only auto-generated
# output from `npm run types`.
lib/generated/
generated/

# Leftover synthetic output that may exist outside dogfood/ from
# prior pipeline runs.  Safe to remove once all paths are migrated.
scenarios/synthetic/
