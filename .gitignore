node_modules/
dist/
playwright-report/
test-results/
.npm-cache
.tools

# ── Runtime engine (.tesseract) ──────────────────────────────────
# Bulk-ignore everything under .tesseract/; the engine recreates it.
# Allowlist only governance anchors that must survive across clones.
.tesseract/*
!.tesseract/policy/
!.tesseract/policy/trust-policy.yaml
!.tesseract/benchmarks/
!.tesseract/benchmarks/scorecard.json

# ── Dogfood clean room ───────────────────────────────────────────
# Until production suites exist, all generated output is clean-room
# output.  The flywheel proves itself by regenerating from scratch
# each run.  Nothing it produces is tracked.
#
# All compiler output:
generated/
# Synthetic scenarios and fixtures (ID range 2xxxx):
scenarios/synthetic/
fixtures/ado/2*.json
.ado-sync/snapshots/2*.json
.ado-sync/archive/2*/
